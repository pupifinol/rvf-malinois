#!/usr/bin/env sh
# RVF Malinois — pre-commit hook
#
# Runs lint-staged so only the files about to be committed are linted and
# formatted. Full lint/typecheck/tests run in CI; the hook stays fast.
#
# Git on macOS launches hooks with a minimal PATH that excludes user-level
# shims like ~/.local/bin (where corepack puts pnpm) and Homebrew's bin
# directories. Augment PATH for common locations so the hook works on a
# default developer machine without per-host configuration.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

# Prefer a real pnpm on PATH; fall back to corepack (bundled with Node).
if command -v pnpm >/dev/null 2>&1; then
  pnpm exec lint-staged
else
  corepack pnpm exec lint-staged
fi
