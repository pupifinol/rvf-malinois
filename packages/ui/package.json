{
  "name": "@rvf/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Industrial design system foundations for RVF Malinois (tokens, Tailwind preset, primitives)",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens/tokens.css",
    "./tailwind-preset": "./src/tailwind/preset.ts",
    "./primitives": "./src/primitives/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@rvf/types": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.14"
  },
  "devDependencies": {
    "@rvf/config": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
