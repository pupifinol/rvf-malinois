{
  "name": "@rvf/types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types and contracts for RVF Malinois (branded IDs, telemetry envelope, alarm shape)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./brand": "./src/brand.ts",
    "./domain": "./src/domain.ts",
    "./telemetry": "./src/telemetry.ts",
    "./realtime": "./src/realtime.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@rvf/config": "workspace:*",
    "eslint": "^9.14.0",
    "typescript": "^5.6.3"
  }
}
