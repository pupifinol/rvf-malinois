# RVF Malinois — Local development environment variables
# Copy this file to .env and adjust as needed.

# --- Database (TimescaleDB-flavored Postgres in docker-compose) ---
POSTGRES_USER=rvf
POSTGRES_PASSWORD=rvf_dev_password
POSTGRES_DB=rvf_malinois
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://rvf:rvf_dev_password@localhost:5432/rvf_malinois?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Backend ---
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# --- Frontend (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
