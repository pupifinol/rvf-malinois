// =============================================================================
// RVF Malinois — Prisma schema (Phase F4.2 baseline)
// =============================================================================
//
// Canonical source of truth:
//   database/schema/RVF_Malinois_F4_1_PostgreSQL_Schema.sql   (commit a475066)
//   docs/architecture/RVF_Malinois_F4_Database_Foundation_Architecture.md
//                                                            (commit f36923a)
//   docs/adr/ADR-007_RVF_Malinois_Database_Foundation.md     (commit 8147399)
//   docs/architecture/RVF_Malinois_F4_2A_Prisma_Reconciliation_Plan.md
//                                                            (commit 7bd6103)
//   docs/architecture/RVF_Malinois_F4_2B_Insulation_Strategy_Confirmation.md
//                                                            (commit a8862e2)
//
// Notes carried over from F4.1 SQL (do not weaken):
//   - UUID primary keys via pgcrypto's gen_random_uuid().
//   - No TimescaleDB. telemetry_readings is a plain table, convertible to a
//     hypertable later without redesign.
//   - Multi-tenant isolation is column-level (tenant_id + FK) on every
//     operational / canonical table.
//   - CHECK constraints (status enums, kind enums, etc.) are NOT modeled as
//     Prisma `enum` blocks. They live as CHECK constraints in the migration
//     SQL. Prisma fields are plain `String`; allowed values are documented in
//     /// comments.
//   - Partial unique indexes (e.g. WHERE is_current = TRUE) are NOT modeled
//     in Prisma. They are created in the migration via raw SQL.
//   - live_readings_projection (DERIVED view, not canonical) is NOT modeled
//     in Prisma. It is defined as raw SQL in the migration. F4.6 picks the
//     final implementation (view, materialized view, upsert table).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// =============================================================================
// A. Tenancy and identity
// =============================================================================

/// Multi-client root (F4 §D Tenant; ADR-002 residency).
/// `status` is constrained by CHECK to ('active', 'inactive') in the migration.
model Tenant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  status        String   @default("active")
  residencyHint String?  @map("residency_hint")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  users                  User[]
  measurementUnits       MeasurementUnit[]
  sensors                Sensor[]
  transmitterDevices     TransmitterDevice[]
  sensorTagBindings      SensorTagBinding[]
  unitConfigurations     UnitConfiguration[]
  unitOperatingEnvelopes UnitOperatingEnvelope[]
  alarmRules             AlarmRule[]
  alarmEvents            AlarmEvent[]
  wells                  Well[]
  jobs                   Job[]
  commissioningSnapshots CommissioningSnapshot[]
  telemetryReadings      TelemetryReading[]
  integrationSources     IntegrationSource[]
  integrationMappings    IntegrationMapping[]
  auditLogs              AuditLog[]

  @@map("tenants")
}

/// Actor identity for audit references. Real authentication is explicitly out
/// of scope for F4 (ADR-007 §7).
/// `role`  CHECK in ('system','admin','engineer','operator','viewer').
/// `status` CHECK in ('active','inactive').
model User {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  displayName String   @map("display_name")
  role        String   @default("viewer")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unitConfigurationsCreated     UnitConfiguration[]     @relation("UnitConfigurationCreatedBy")
  unitOperatingEnvelopesCreated UnitOperatingEnvelope[] @relation("UnitOperatingEnvelopeCreatedBy")
  alarmRulesCreated             AlarmRule[]             @relation("AlarmRuleCreatedBy")
  alarmEventsAcknowledged       AlarmEvent[]            @relation("AlarmEventAcknowledgedBy")
  jobsEngineered                Job[]                   @relation("JobEngineer")
  auditLogs                     AuditLog[]              @relation("AuditLogActor")

  @@index([tenantId], map: "users_tenant_idx")
  @@map("users")
}

// =============================================================================
// B. Equipment catalog and instrumentation
// =============================================================================

/// Template for a class of equipment (EMMAD, EMGAD). Not tenant-scoped: the
/// catalog of equipment classes is shared across the platform.
model EquipmentType {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String   @unique
  description           String?
  defaultSensorTemplate Json?    @map("default_sensor_template")
  pidReference          String?  @map("pid_reference")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  measurementUnits MeasurementUnit[]

  @@map("equipment_types")
}

/// Physical, reusable unit of measurement equipment (EMMAD-01, EMMAD-02, ...).
/// `status` CHECK in ('active','inactive','offline','maintenance').
/// `operating_profile` CHECK in ('high_pressure_high_flow','medium','low','custom').
/// Unique by (tenant_id, code).
model MeasurementUnit {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  equipmentTypeId  String   @map("equipment_type_id") @db.Uuid
  code             String
  serialNumber     String?  @map("serial_number")
  name             String
  status           String   @default("active")
  operatingProfile String   @default("custom") @map("operating_profile")
  location         String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  equipmentType          EquipmentType           @relation(fields: [equipmentTypeId], references: [id], onDelete: Restrict)
  sensors                Sensor[]
  unitConfigurations     UnitConfiguration[]
  unitOperatingEnvelopes UnitOperatingEnvelope[]
  alarmRules             AlarmRule[]
  alarmEvents            AlarmEvent[]
  jobs                   Job[]
  commissioningSnapshots CommissioningSnapshot[]
  telemetryReadings      TelemetryReading[]
  integrationMappings    IntegrationMapping[]

  @@unique([tenantId, code], map: "measurement_units_tenant_code_uk")
  @@index([tenantId], map: "measurement_units_tenant_idx")
  @@index([equipmentTypeId], map: "measurement_units_equipment_type_idx")
  @@map("measurement_units")
}

/// Logical measurement point on a measurement_unit. Persists across
/// transmitter replacements.
/// `type` CHECK in ('pressure','temperature','flow','vibration','volume',
///                  'level','gas_composition','digital_status').
model Sensor {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  unitId          String   @map("unit_id") @db.Uuid
  type            String
  name            String
  instrumentTag   String   @map("instrument_tag")
  enabled         Boolean  @default(true)
  minRange        Decimal? @map("min_range") @db.Decimal
  maxRange        Decimal? @map("max_range") @db.Decimal
  engineeringUnit String   @map("engineering_unit")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit                MeasurementUnit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  transmitterDevices  TransmitterDevice[]
  sensorTagBindings   SensorTagBinding[]
  telemetryReadings   TelemetryReading[]
  integrationMappings IntegrationMapping[]

  @@index([tenantId], map: "sensors_tenant_idx")
  @@index([unitId], map: "sensors_unit_idx")
  @@map("sensors")
}

/// Physical / digital device implementing a sensor. Separate table so
/// calibration, firmware, and replacement history are captured per device.
/// `protocol`            CHECK in ('4-20mA','HART','Modbus','OPC-UA','wireless').
/// `installation_status` CHECK in ('installed','removed','on_bench','replaced').
/// Partial index on (sensor_id) WHERE installation_status='installed'
/// is created in raw SQL in the migration.
model TransmitterDevice {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  sensorId               String    @map("sensor_id") @db.Uuid
  serialNumber           String    @map("serial_number")
  manufacturer           String
  model                  String
  protocol               String
  signalType             String    @map("signal_type")
  modbusAddress          Int?      @map("modbus_address")
  registerMapReference   String?   @map("register_map_reference")
  channel                String?
  firmwareVersion        String?   @map("firmware_version")
  calibrationDate        DateTime? @map("calibration_date") @db.Date
  calibrationRangeMin    Decimal?  @map("calibration_range_min") @db.Decimal
  calibrationRangeMax    Decimal?  @map("calibration_range_max") @db.Decimal
  calibrationReference   String?   @map("calibration_reference")
  batteryStatus          String?   @map("battery_status")
  installationStatus     String    @default("installed") @map("installation_status")
  installedAt            DateTime? @map("installed_at") @db.Timestamptz(6)
  removedAt              DateTime? @map("removed_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sensor Sensor @relation(fields: [sensorId], references: [id], onDelete: Restrict)

  @@index([tenantId], map: "transmitter_devices_tenant_idx")
  @@index([sensorId], map: "transmitter_devices_sensor_idx")
  @@map("transmitter_devices")
}

// =============================================================================
// C. Canonical tag dictionary and sensor bindings (ADR-003)
// =============================================================================

/// RVF's fixed measurement vocabulary (p_inlet, t_gas_out, q_liquid, ...).
/// Owned by RVF; globally unique; not tenant-scoped.
model CanonicalTag {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @unique
  displayName    String   @map("display_name")
  canonicalUnit  String   @map("canonical_unit")
  category       String
  precision      Int      @default(2)
  description    String?
  deprecated     Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sensorTagBindings   SensorTagBinding[]
  alarmRules          AlarmRule[]
  alarmEvents         AlarmEvent[]
  telemetryReadings   TelemetryReading[]
  integrationMappings IntegrationMapping[]

  @@map("canonical_tags")
}

/// Effective-dated mapping from sensor to canonical tag (ADR-003). At most one
/// row per sensor is currently active (effective_to IS NULL). The partial
/// unique index enforcing that invariant is created in raw SQL.
model SensorTagBinding {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  sensorId       String    @map("sensor_id") @db.Uuid
  canonicalTagId String    @map("canonical_tag_id") @db.Uuid
  effectiveFrom  DateTime  @map("effective_from") @db.Timestamptz(6)
  effectiveTo    DateTime? @map("effective_to") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sensor       Sensor       @relation(fields: [sensorId], references: [id], onDelete: Restrict)
  canonicalTag CanonicalTag @relation(fields: [canonicalTagId], references: [id], onDelete: Restrict)

  @@index([tenantId], map: "sensor_tag_bindings_tenant_idx")
  @@index([sensorId], map: "sensor_tag_bindings_sensor_idx")
  @@index([canonicalTagId], map: "sensor_tag_bindings_canonical_tag_idx")
  @@index([effectiveFrom, effectiveTo], map: "sensor_tag_bindings_effective_idx")
  @@map("sensor_tag_bindings")
}

// =============================================================================
// D. Per-unit operational configuration (F4 §E)
// =============================================================================

/// Versioned per-unit operational configuration. Only one row per unit may
/// have is_current = TRUE (enforced by a partial unique index in raw SQL).
model UnitConfiguration {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                  String   @map("tenant_id") @db.Uuid
  unitId                    String   @map("unit_id") @db.Uuid
  version                   Int
  configuration             Json?
  enabledSensors            Json?    @map("enabled_sensors")
  engineeringUnitOverrides  Json?    @map("engineering_unit_overrides")
  displayPrecisionOverrides Json?    @map("display_precision_overrides")
  isCurrent                 Boolean  @default(false) @map("is_current")
  createdBy                 String?  @map("created_by") @db.Uuid
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit    MeasurementUnit @relation(fields: [unitId], references: [id], onDelete: Restrict)
  creator User?           @relation("UnitConfigurationCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([unitId, version], map: "unit_configurations_unit_version_uk")
  @@index([tenantId], map: "unit_configurations_tenant_idx")
  @@index([unitId], map: "unit_configurations_unit_idx")
  @@map("unit_configurations")
}

/// Per-unit operating limits (F4 §D, §E). HP units and LP units carry
/// different envelopes; there is no global envelope by design. Only one row
/// per unit may have is_current = TRUE (partial unique index in raw SQL).
model UnitOperatingEnvelope {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String   @map("tenant_id") @db.Uuid
  unitId                  String   @map("unit_id") @db.Uuid
  version                 Int
  maxPressure             Decimal? @map("max_pressure") @db.Decimal
  maxFlowRate             Decimal? @map("max_flow_rate") @db.Decimal
  maxTemperature          Decimal? @map("max_temperature") @db.Decimal
  maxVibration            Decimal? @map("max_vibration") @db.Decimal
  maxDifferentialPressure Decimal? @map("max_differential_pressure") @db.Decimal
  maxVolume               Decimal? @map("max_volume") @db.Decimal
  maxGasRate              Decimal? @map("max_gas_rate") @db.Decimal
  engineeringUnitSet      Json?    @map("engineering_unit_set")
  isCurrent               Boolean  @default(false) @map("is_current")
  createdBy               String?  @map("created_by") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit    MeasurementUnit @relation(fields: [unitId], references: [id], onDelete: Restrict)
  creator User?           @relation("UnitOperatingEnvelopeCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([unitId, version], map: "unit_operating_envelopes_unit_version_uk")
  @@index([tenantId], map: "unit_operating_envelopes_tenant_idx")
  @@index([unitId], map: "unit_operating_envelopes_unit_idx")
  @@map("unit_operating_envelopes")
}

// =============================================================================
// E. Alarm model (ADR-005, F4 §G)
// =============================================================================

/// Per-unit, per-canonical-tag alarm rule (ADR-005). Versioned; only one row
/// per (unit, canonical_tag, severity) may be current at a time (partial
/// unique index in raw SQL).
/// `severity` CHECK in ('info','warning','critical').
model AlarmRule {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  unitId               String   @map("unit_id") @db.Uuid
  canonicalTagId       String   @map("canonical_tag_id") @db.Uuid
  severity             String
  enabled              Boolean  @default(true)
  lowLowThreshold      Decimal? @map("low_low_threshold") @db.Decimal
  lowThreshold         Decimal? @map("low_threshold") @db.Decimal
  highThreshold        Decimal? @map("high_threshold") @db.Decimal
  highHighThreshold    Decimal? @map("high_high_threshold") @db.Decimal
  deadband             Decimal? @db.Decimal
  delaySeconds         Int?     @map("delay_seconds")
  messageTemplate      String?  @map("message_template")
  version              Int
  isCurrent            Boolean  @default(false) @map("is_current")
  createdBy            String?  @map("created_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit         MeasurementUnit  @relation(fields: [unitId], references: [id], onDelete: Restrict)
  canonicalTag CanonicalTag     @relation(fields: [canonicalTagId], references: [id], onDelete: Restrict)
  creator      User?            @relation("AlarmRuleCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  thresholds   AlarmThreshold[]
  events       AlarmEvent[]

  @@unique([unitId, canonicalTagId, severity, version], map: "alarm_rules_unit_tag_severity_version_uk")
  @@index([tenantId], map: "alarm_rules_tenant_idx")
  @@index([unitId], map: "alarm_rules_unit_idx")
  @@index([canonicalTagId], map: "alarm_rules_canonical_tag_idx")
  @@map("alarm_rules")
}

/// Placeholder for complex / multi-step thresholds (F4 §G). Not required to be
/// populated in F4.2; reserved for future use.
/// `kind` CHECK in ('low_low','low','high','high_high','rate_of_change').
model AlarmThreshold {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alarmRuleId   String   @map("alarm_rule_id") @db.Uuid
  kind          String
  value         Decimal  @db.Decimal
  deadband      Decimal? @db.Decimal
  delaySeconds  Int?     @map("delay_seconds")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  alarmRule AlarmRule @relation(fields: [alarmRuleId], references: [id], onDelete: Cascade)

  @@index([alarmRuleId], map: "alarm_thresholds_rule_idx")
  @@map("alarm_thresholds")
}

/// Persistent alarm occurrences. Lifecycle: active -> acknowledged -> cleared.
/// Partial index for the "active" board is created in raw SQL.
/// `severity`           CHECK in ('info','warning','critical').
/// `state`              CHECK in ('active','acknowledged','cleared').
/// `threshold_violated` CHECK in ('low_low','low','high','high_high','rate_of_change').
model AlarmEvent {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  unitId             String    @map("unit_id") @db.Uuid
  canonicalTagId     String    @map("canonical_tag_id") @db.Uuid
  alarmRuleId        String?   @map("alarm_rule_id") @db.Uuid
  severity           String
  triggeredValue     Decimal   @map("triggered_value") @db.Decimal
  thresholdViolated  String    @map("threshold_violated")
  state              String    @default("active")
  firstTriggeredAt   DateTime  @map("first_triggered_at") @db.Timestamptz(6)
  acknowledgedAt     DateTime? @map("acknowledged_at") @db.Timestamptz(6)
  acknowledgedBy     String?   @map("acknowledged_by") @db.Uuid
  clearedAt          DateTime? @map("cleared_at") @db.Timestamptz(6)
  jobId              String?   @map("job_id") @db.Uuid
  ruleSnapshot       Json      @map("rule_snapshot")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit           MeasurementUnit @relation(fields: [unitId], references: [id], onDelete: Restrict)
  canonicalTag   CanonicalTag    @relation(fields: [canonicalTagId], references: [id], onDelete: Restrict)
  alarmRule      AlarmRule?      @relation(fields: [alarmRuleId], references: [id], onDelete: SetNull)
  acknowledgedByUser User?       @relation("AlarmEventAcknowledgedBy", fields: [acknowledgedBy], references: [id], onDelete: SetNull)
  job            Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "alarm_events_tenant_idx")
  @@index([unitId, firstTriggeredAt(sort: Desc)], map: "alarm_events_unit_time_idx")
  @@index([canonicalTagId], map: "alarm_events_canonical_tag_idx")
  @@index([jobId], map: "alarm_events_job_idx")
  @@map("alarm_events")
}

// =============================================================================
// F. Wells and jobs (catalog + operation)
// =============================================================================

/// Operational subject being tested (Modelo de Dominio). client_id is
/// reserved for future use when client identity is separated from tenant.
model Well {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  clientId      String?  @map("client_id") @db.Uuid
  name          String
  fieldOrSite   String?  @map("field_or_site")
  location      String?
  type          String?
  fluid         String?
  designLimits  Json?    @map("design_limits")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  jobs   Job[]

  @@index([tenantId], map: "wells_tenant_idx")
  @@map("wells")
}

/// Deployment of a measurement_unit at a well for a period.
/// `status` CHECK in ('programmed','in_progress','closed').
/// commissioning_snapshot_id FK breaks a circular dependency: the FK is
/// declared here and validated against commissioning_snapshots, which itself
/// references jobs(id). Prisma migrate sequences the SQL correctly.
model Job {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                  String    @map("tenant_id") @db.Uuid
  wellId                    String    @map("well_id") @db.Uuid
  unitId                    String    @map("unit_id") @db.Uuid
  commissioningSnapshotId   String?   @map("commissioning_snapshot_id") @db.Uuid
  engineerId                String?   @map("engineer_id") @db.Uuid
  status                    String    @default("programmed")
  startedAt                 DateTime? @map("started_at") @db.Timestamptz(6)
  closedAt                  DateTime? @map("closed_at") @db.Timestamptz(6)
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                   Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  well                     Well                    @relation(fields: [wellId], references: [id], onDelete: Restrict)
  unit                     MeasurementUnit         @relation(fields: [unitId], references: [id], onDelete: Restrict)
  commissioningSnapshot    CommissioningSnapshot?  @relation("JobCurrentSnapshot", fields: [commissioningSnapshotId], references: [id], onDelete: SetNull)
  engineer                 User?                   @relation("JobEngineer", fields: [engineerId], references: [id], onDelete: SetNull)
  alarmEvents              AlarmEvent[]
  telemetryReadings        TelemetryReading[]
  commissioningSnapshots   CommissioningSnapshot[] @relation("CommissioningSnapshotJob")

  @@index([tenantId], map: "jobs_tenant_idx")
  @@index([wellId], map: "jobs_well_idx")
  @@index([unitId], map: "jobs_unit_idx")
  @@index([commissioningSnapshotId], map: "jobs_commissioning_snapshot_idx")
  @@map("jobs")
}

/// Immutable, frozen configuration at commissioning (ADR-005). SQL alone
/// cannot fully enforce immutability without triggers or REVOKE; the
/// `immutable` flag + CHECK constraint document the contract, and a future
/// hardening pass will add trigger / GRANT enforcement.
model CommissioningSnapshot {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  jobId                 String   @map("job_id") @db.Uuid
  unitId                String   @map("unit_id") @db.Uuid
  takenAt               DateTime @default(now()) @map("taken_at") @db.Timestamptz(6)
  effectiveThresholds   Json     @map("effective_thresholds")
  sensorMappings        Json     @map("sensor_mappings")
  engineeringEnvelope   Json     @map("engineering_envelope")
  ruleVersions          Json     @map("rule_versions")
  immutable             Boolean  @default(true)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  job        Job             @relation("CommissioningSnapshotJob", fields: [jobId], references: [id], onDelete: Restrict)
  unit       MeasurementUnit @relation(fields: [unitId], references: [id], onDelete: Restrict)
  currentFor Job[]           @relation("JobCurrentSnapshot")

  @@index([tenantId], map: "commissioning_snapshots_tenant_idx")
  @@index([jobId], map: "commissioning_snapshots_job_idx")
  @@index([unitId], map: "commissioning_snapshots_unit_idx")
  @@map("commissioning_snapshots")
}

// =============================================================================
// G. Telemetry readings (canonical, append-only)
// =============================================================================

/// Canonical persisted telemetry. Plain PostgreSQL table; convertible to a
/// TimescaleDB hypertable later without redesign. Append-only by architecture;
/// SQL-level UPDATE/DELETE restrictions are a later concern.
/// `quality` CHECK in ('good','uncertain','bad').
/// `source`  CHECK in ('mock','manual','field_gateway','historian','plc',
///                     'mqtt','node_red','opc_ua','modbus','edge_gateway').
/// Partial index on (job_id, timestamp DESC) WHERE job_id IS NOT NULL is
/// created in raw SQL.
model TelemetryReading {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  unitId          String   @map("unit_id") @db.Uuid
  sensorId        String   @map("sensor_id") @db.Uuid
  canonicalTagId  String   @map("canonical_tag_id") @db.Uuid
  timestamp       DateTime @db.Timestamptz(6)
  value           Decimal  @db.Decimal
  engineeringUnit String   @map("engineering_unit")
  quality         String
  source          String
  ingestionId     String?  @map("ingestion_id")
  sequence        BigInt?
  jobId           String?  @map("job_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit         MeasurementUnit @relation(fields: [unitId], references: [id], onDelete: Restrict)
  sensor       Sensor          @relation(fields: [sensorId], references: [id], onDelete: Restrict)
  canonicalTag CanonicalTag    @relation(fields: [canonicalTagId], references: [id], onDelete: Restrict)
  job          Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([unitId, canonicalTagId, timestamp(sort: Desc)], map: "telemetry_readings_unit_tag_time_idx")
  @@index([tenantId, timestamp(sort: Desc)], map: "telemetry_readings_tenant_time_idx")
  @@index([sensorId, timestamp(sort: Desc)], map: "telemetry_readings_sensor_time_idx")
  @@map("telemetry_readings")
}

// NOTE: live_readings_projection is a DERIVED SQL view defined in the
// migration. It is intentionally NOT modeled in Prisma — consumers read it
// via $queryRaw. F4.6 picks the final implementation (view, materialized
// view, upsert-maintained projection table, or application cache).

// =============================================================================
// H. Integration metadata (placeholders, F4 §I)
// =============================================================================

/// Future inbound integration channel. credentials_reference points at an
/// external secret store; secrets are never stored inline.
/// `kind`   CHECK in ('mqtt','node_red','thingsboard','opc_ua','modbus',
///                    'edge_gateway','plc','manual','historian').
/// `status` CHECK in ('active','inactive').
model IntegrationSource {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  kind                  String
  name                  String
  status                String   @default("inactive")
  config                Json     @default("{}")
  credentialsReference  String?  @map("credentials_reference")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  mappings IntegrationMapping[]

  @@index([tenantId], map: "integration_sources_tenant_idx")
  @@map("integration_sources")
}

/// Translation from external identifier to canonical (unit, sensor,
/// canonical_tag) triple. external_identifier is unique per integration_source.
model IntegrationMapping {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                  String   @map("tenant_id") @db.Uuid
  integrationSourceId       String   @map("integration_source_id") @db.Uuid
  externalIdentifier        String   @map("external_identifier")
  unitId                    String   @map("unit_id") @db.Uuid
  sensorId                  String?  @map("sensor_id") @db.Uuid
  canonicalTagId            String?  @map("canonical_tag_id") @db.Uuid
  engineeringUnitOverride   String?  @map("engineering_unit_override")
  transformationReference   String?  @map("transformation_reference")
  enabled                   Boolean  @default(false)
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  integrationSource IntegrationSource @relation(fields: [integrationSourceId], references: [id], onDelete: Restrict)
  unit              MeasurementUnit   @relation(fields: [unitId], references: [id], onDelete: Restrict)
  sensor            Sensor?           @relation(fields: [sensorId], references: [id], onDelete: SetNull)
  canonicalTag      CanonicalTag?     @relation(fields: [canonicalTagId], references: [id], onDelete: SetNull)

  @@unique([integrationSourceId, externalIdentifier], map: "integration_mappings_source_external_uk")
  @@index([tenantId], map: "integration_mappings_tenant_idx")
  @@index([integrationSourceId], map: "integration_mappings_source_idx")
  @@index([unitId], map: "integration_mappings_unit_idx")
  @@index([sensorId], map: "integration_mappings_sensor_idx")
  @@index([canonicalTagId], map: "integration_mappings_canonical_tag_idx")
  @@map("integration_mappings")
}

// =============================================================================
// I. Audit log (append-only, central)
// =============================================================================

/// Single append-only audit table (F4 §H). Same enforcement note as
/// commissioning_snapshots and telemetry_readings — append-only is documented
/// by architecture and CHECK constraints; trigger / GRANT hardening is a
/// later concern.
/// `action` CHECK in ('created','updated','deleted','acknowledged','cleared',
///                    'calibrated','replaced','commissioned','closed').
model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  actorId       String?  @map("actor_id") @db.Uuid
  action        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id") @db.Uuid
  before        Json?
  after         Json?
  correlationId String?  @map("correlation_id") @db.Uuid
  ipAddress     String?  @map("ip_address") @db.Inet
  userAgent     String?  @map("user_agent")
  at            DateTime @default(now()) @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actor  User?  @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, at(sort: Desc)], map: "audit_logs_tenant_at_idx")
  @@index([entityType, entityId], map: "audit_logs_entity_idx")
  @@index([actorId], map: "audit_logs_actor_idx")
  @@index([correlationId], map: "audit_logs_correlation_idx")
  @@map("audit_logs")
}
